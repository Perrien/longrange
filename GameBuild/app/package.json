{
  "name": "longrange",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/check-engine.mjs && vite",
    "build": "node scripts/check-engine.mjs && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/check-engine.mjs && vitest run",
    "test:watch": "node scripts/check-engine.mjs && vitest",
    "engine:build": "cd ../engine && emcmake cmake -S . -B build-wasm && emmake make -C build-wasm -j"
  },
  "dependencies": {
    "idb": "8.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
