{
 "_readme": "Catalog starting values for Increment-2 (gear catalog 2.2 + hidden-truth model 2.1). Nominal + SD per field (decision D3: bell-curve draw, clamp ±3 SD). Imperial as sourced; SI (…Mps/…Kg/…M) added for the engine. SECONDARY source — indicative starting values, spot-check against Litz before shipping.",
 "_provenance": "Extracted from AmmoResearch.txt + RifleResearch.txt (plain-text copies of two AI deep-research reports, 2026-07-16). The .md/pdf/html/docx exports of these reports cropped the equation images and lost SD/range values; the text copies did not.",
 "_modelMapping": {
  "ammoLot.meanMvShift": "hidden: N(0, loads.*.lotMeanMvShiftSdFps). This lot's true mean MV vs box.",
  "ammoLot.mvSd": "hidden: this lot's true per-shot MV SD ~ N(perShotMvSdFps.nom, .sd).",
  "ammoLot.trueBc": "hidden: N(loads.*.trueBc, trueBc×lotBcVarPct/100). Box/believed BC = boxBcG1adv/boxBcG7adv (optimistic).",
  "ammoLot.boxMv": "believed nominal = boxMvFps (advertised @ boxMvBarrelIn) or measMvFps (realistic).",
  "rifleInstance.mvOffset": "hidden: N(0, rifle.barrelToBarrelMvSpreadFps.nom). Each rifle copy's fixed MV bias.",
  "rifleInstance.inherentPrecision": "hidden: rifle.inherentPrecisionMOA[tier] for the model's tier (nom + sd).",
  "rifleModel": "catalog attrs: barrelLength, twist(+gating), weight, recoil, barrelLife."
 },
 "_designSet_NOT_in_research": {
  "_note": "Not in the research — game-design values (artistic license, owner-approved 2026-07-16). Tunable.",
  "rifleInstance.zeroOffsetHV": {
   "model": "each axis (h,v) ~ N(0, sdMOA), clamp ±3·sd. A fresh instance starts visibly off-zero; player dials it out in the 2.3 zeroing flow.",
   "sdMOA": 1.0,
   "sdMRAD": 0.29,
   "clampMOA": 3.0,
   "rationale": "~1 MOA typical mount/bore-sight error, up to ~3 MOA — small at 100 yd, clearly off downrange, zeroable in a group or two."
  },
  "ammoLot.perShotBcSdFraction": {
   "model": "per-SHOT BC scatter (engine bcSdFraction), distinct from the lot-to-lot lotBcVarPct in the loads. By load class.",
   "match": 0.005,
   "bulk": 0.015,
   "rationale": "keeps the current game provisional (0.5%/1.5%); roughly ⅓ of the sourced lot-to-lot BC variance — per-shot should be tighter than lot-to-lot."
  }
 },
 "units": {
  "mv": "fps (+Mps=m/s)",
  "weight": "gr (+Kg)",
  "barrel": "in (+M)",
  "precision": "MOA",
  "tempSens": "fps per 10°F",
  "spreads": "nominal + SD"
 },
